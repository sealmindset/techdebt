# =============================================================================
# TechDebt -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Placeholders (replaced during /make-it build phase):
#   TechDebt          - human-readable app name
#   techdebt          - kebab-case app name
#   3100     - host port for frontend (e.g., 3100)
#   8100      - host port for backend (e.g., 8100)
#   5500           - host port for PostgreSQL (e.g., 5500)
#   10090    - host port for mock-oidc (e.g., 10190)
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://techdebt:techdebt@localhost:5500/techdebt

# ---------------------------------------------------------------------------
# OIDC Authentication
# ---------------------------------------------------------------------------
# For local development, these point to the mock-oidc container.
# For production, replace with your Azure AD / Entra ID values.
OIDC_ISSUER_URL=http://localhost:10090
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:8100

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
ENFORCE_SECRETS=false

# ---------------------------------------------------------------------------
# Activity Log
# ---------------------------------------------------------------------------
LOG_BUFFER_SIZE=10000
# Cribl Stream forwarding (optional -- leave empty to disable)
CRIBL_STREAM_URL=
CRIBL_STREAM_TOKEN=

# ---------------------------------------------------------------------------
# Additional Service URLs
# ---------------------------------------------------------------------------
WORKDAY_BASE_URL=http://localhost:9001
AUDITBOARD_BASE_URL=http://localhost:9002
ENTRA_ID_BASE_URL=http://localhost:9003
