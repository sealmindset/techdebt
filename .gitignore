# =============================================================================
# .gitignore -- FastAPI + Next.js application
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
*.py[cod]
*$py.class
.venv/
venv/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/
frontend/.next/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker volumes
# ---------------------------------------------------------------------------
postgres_data/

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
dist/
build/
*.egg-info/

# ---------------------------------------------------------------------------
# Test
# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Terraform (generated as DevOps handoff artifact)
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
